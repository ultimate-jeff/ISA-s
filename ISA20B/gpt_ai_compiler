import re

# =====================
# TOKENIZER
# =====================

TOKEN_REGEX = [
    ("NUMBER", r"\d+"),
    ("ID", r"[a-zA-Z_]\w*"),
    ("OP", r"[+\-*/=<>!]"),
    ("LPAREN", r"\("),
    ("RPAREN", r"\)"),
    ("LBRACE", r"\{"),
    ("RBRACE", r"\}"),
    ("SEMICOLON", r";"),
    ("COMMA", r","),
    ("SKIP", r"[ \t\n]+"),
]

def tokenize(code):
    tokens = []
    i = 0
    while i < len(code):
        for name, regex in TOKEN_REGEX:
            match = re.match(regex, code[i:])
            if match:
                text = match.group(0)
                if name != "SKIP":
                    tokens.append((name, text))
                i += len(text)
                break
        else:
            raise SyntaxError(f"Unexpected char: {code[i]}")
    return tokens

# =====================
# PARSER (VERY SIMPLE)
# =====================

class Parser:
    def __init__(self, tokens):
        self.tokens = tokens
        self.pos = 0

    def peek(self):
        return self.tokens[self.pos] if self.pos < len(self.tokens) else None

    def eat(self, t=None):
        tok = self.peek()
        if tok is None:
            return None
        if t and tok[0] != t:
            raise SyntaxError(f"Expected {t}, got {tok}")
        self.pos += 1
        return tok

    def parse(self):
        stmts = []
        while self.peek():
            stmts.append(self.statement())
        return stmts

    def statement(self):
        tok = self.peek()

        if tok[1] == "int":
            return self.decl()
        elif tok[1] == "if":
            return self.if_stmt()
        elif tok[1] == "while":
            return self.while_stmt()
        else:
            return self.assign()

    def decl(self):
        self.eat()  # int
        name = self.eat("ID")[1]
        self.eat("OP")  # =
        expr = self.expr()
        self.eat("SEMICOLON")
        return ("decl", name, expr)

    def assign(self):
        name = self.eat("ID")[1]
        self.eat("OP")
        expr = self.expr()
        self.eat("SEMICOLON")
        return ("assign", name, expr)

    def if_stmt(self):
        self.eat()  # if
        self.eat("LPAREN")
        cond = self.condition()
        self.eat("RPAREN")
        body = self.block()
        return ("if", cond, body)

    def while_stmt(self):
        self.eat()  # while
        self.eat("LPAREN")
        cond = self.condition()
        self.eat("RPAREN")
        body = self.block()
        return ("while", cond, body)

    def block(self):
        self.eat("LBRACE")
        stmts = []
        while self.peek()[0] != "RBRACE":
            stmts.append(self.statement())
        self.eat("RBRACE")
        return stmts

    def condition(self):
        left = self.eat("ID")[1]
        op = self.eat("OP")[1]
        right = self.eat("ID")[1]
        return (left, op, right)

    def expr(self):
        tok = self.peek()
        if tok[0] == "NUMBER":
            return ("num", int(self.eat()[1]))
        elif tok[0] == "ID":
            left = self.eat()[1]
            if self.peek() and self.peek()[0] == "OP":
                op = self.eat()[1]
                right = self.eat()[1]
                return ("binop", left, op, right)
            return ("var", left)

# =====================
# CODEGEN
# =====================

class CodeGen:
    def __init__(self):
        self.vars = {}
        self.reg_pool = list(range(32))
        self.code = []
        self.labels = {}
        self.label_id = 0

    def new_label(self):
        self.label_id += 1
        return f"L{self.label_id}"

    def alloc(self, name):
        if name in self.vars:
            return self.vars[name]
        reg = self.reg_pool.pop(0)
        self.vars[name] = reg
        return reg

    def get(self, name):
        if name.isdigit():
            return ("imm", int(name))
        return ("reg", self.vars[name])

    def emit(self, line):
        self.code.append(line)

    def mark_label(self, label):
        self.labels[label] = len(self.code)

    def resolve_labels(self):
        new_code = []
        for i, line in enumerate(self.code):
            if line.endswith(":"):
                continue

            parts = line.split()
            if parts[0] == "jmp":
                target = parts[1]
                if target in self.labels:
                    addr = self.labels[target]
                    new_code.append(f"jmp {addr}")
                else:
                    new_code.append(line)
            else:
                new_code.append(line)

        return new_code

    def compile(self, ast):
        # generate program normally
        for stmt in ast:
            self.gen(stmt)

        resolved = self.resolve_labels()

        PROGRAM_SIZE = len(resolved)
        SAFETY = 4   # small buffer
        OFFSET = PROGRAM_SIZE + SAFETY

        # shift all jmp addresses
        shifted = []
        for line in resolved:
            parts = line.split()
            if parts and parts[0] == "jmp":
                addr = int(parts[1])
                shifted.append(f"jmp {addr + OFFSET}")
            else:
                shifted.append(line)

        # build final output
        final = []

        # entry jump
        final.append(f"jmp {OFFSET}")

        # padding (data-safe zone)
        for _ in range(OFFSET - 1):
            final.append("0")

        # program
        final.extend(shifted)

        return "\n".join(final)

    def gen(self, node):
        t = node[0]

        if t == "decl":
            _, name, expr = node
            reg = self.alloc(name)

            if expr[0] == "num":
                self.emit(f"lr {reg} {expr[1]}")

        elif t == "assign":
            _, name, expr = node
            reg = self.vars[name]

            if expr[0] == "var":
                src = self.vars[expr[1]]
                self.emit(f"add {src} 0 {reg}")

            elif expr[0] == "num":
                self.emit(f"lr {reg} {expr[1]}")

            elif expr[0] == "binop":
                a, op, b = expr[1], expr[2], expr[3]

                ra_type, ra = self.get(a)
                rb_type, rb = self.get(b)

                # constant folding
                if ra_type == "imm" and rb_type == "imm":
                    if op == "+":
                        self.emit(f"lr {reg} {ra + rb}")
                    elif op == "-":
                        self.emit(f"lr {reg} {ra - rb}")
                    return

                # immediate optimization
                if rb_type == "imm" and ra_type == "reg":
                    if op == "+":
                        self.emit(f"adi {ra} {rb}")
                        if ra != reg:
                            self.emit(f"add {ra} 0 {reg}")
                    elif op == "-":
                        self.emit(f"sdi {ra} {rb}")
                        if ra != reg:
                            self.emit(f"add {ra} 0 {reg}")
                    return

                # normal reg-reg
                if op == "+":
                    self.emit(f"add {ra} {rb} {reg}")
                elif op == "-":
                    self.emit(f"sub {ra} {rb} {reg}")

        elif t == "if":
            _, cond, body = node
            end = self.new_label()

            self.gen_cond(cond, end, invert=True)

            for s in body:
                self.gen(s)

            self.mark_label(end)

        elif t == "while":
            _, cond, body = node
            start = self.new_label()
            end = self.new_label()

            self.mark_label(start)

            self.gen_cond(cond, end, invert=True)

            for s in body:
                self.gen(s)

            self.emit(f"jmp {start}")
            self.mark_label(end)

    def gen_cond(self, cond, label, invert=False):
        a, op, b = cond

        ra_type, ra = self.get(a)
        rb_type, rb = self.get(b)

        tmp = 31

        # ensure both are in registers
        if ra_type == "imm":
            self.emit(f"lr {tmp} {ra}")
            ra = tmp

        if rb_type == "imm":
            self.emit(f"lr {tmp-1} {rb}")
            rb = tmp-1

        self.emit(f"sub {ra} {rb} {tmp}")

        if op == "==":
            flags = 2
            inv = 2 if invert else 0
        elif op == "!=":
            flags = 2
            inv = 0 if invert else 2
        elif op == "<":
            flags = 16
            inv = 16 if invert else 0
        else:
            flags = 1
            inv = 0

        self.emit(f"cmp {tmp} {flags} {inv}")
        self.emit(f"jmp {label}")

# =====================
# DRIVER
# =====================

def compile_code(code):
    tokens = tokenize(code)
    ast = Parser(tokens).parse()
    asm = CodeGen().compile(ast)
    return asm


if __name__ == "__main__":
    code = """
int a = 0;
int b = 100;

while (a < b) {
    a = a + 2;
    b = b - 1;
}
"""

    asm = compile_code(code)

    print(asm)

    print("Compiled to output.txt")